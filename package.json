{
  "name": "goodbrief",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "ingest-news": "npx tsx scripts/ingest-news.ts",
    "check-feed-health": "npx tsx scripts/check-feed-health.ts",
    "generate-draft": "npx tsx scripts/generate-draft.ts",
    "pipeline:prepare": "npx tsx scripts/run-draft-phase.ts --phase prepare",
    "pipeline:score": "npx tsx scripts/run-draft-phase.ts --phase score",
    "pipeline:semantic-dedup": "npx tsx scripts/run-draft-phase.ts --phase semantic-dedup",
    "pipeline:validate": "npx tsx scripts/run-draft-phase.ts --phase counter-signal-validate",
    "pipeline:select": "npx tsx scripts/run-draft-phase.ts --phase select",
    "pipeline:wrapper-copy": "npx tsx scripts/run-draft-phase.ts --phase wrapper-copy",
    "pipeline:refine": "npx tsx scripts/run-draft-phase.ts --phase refine",
    "pipeline:verify-local": "npx tsx scripts/pipeline-verify-local.ts",
    "pipeline:verify-ingest-e2e": "npx tsx scripts/verify-ingest-e2e.ts",
    "validate-draft": "npx tsx scripts/validate-draft.ts",
    "validate-draft-freshness": "npx tsx scripts/validate-draft-freshness.ts",
    "backfill-legacy-validation": "npx tsx scripts/backfill-legacy-validation.ts",
    "publish-issue": "npx tsx scripts/publish-issue.ts",
    "email:dev": "email dev --dir emails --port 3001",
    "email:preview": "npx tsx scripts/send-newsletter.ts --preview",
    "email:test": "npx tsx scripts/send-newsletter.ts --test",
    "email:send": "npx tsx scripts/send-newsletter.ts --send",
    "notify-draft": "npx tsx scripts/notify-draft.ts",
    "alert-missing-draft": "npx tsx scripts/alert-missing-draft.ts",
    "alert-workflow-failure": "npx tsx scripts/alert-workflow-failure.ts",
    "cleanup-raw-data": "npx tsx scripts/cleanup-raw-data.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@google/generative-ai": "^0.24.1",
    "@react-email/components": "^0.0.30",
    "astro": "^5.0.0",
    "dotenv": "^17.2.3",
    "fastest-levenshtein": "^1.0.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.6.0",
    "rss-parser": "^3.13.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "@cloudflare/workers-types": "^4.20251231.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react-email": "^3.0.7",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0"
  }
